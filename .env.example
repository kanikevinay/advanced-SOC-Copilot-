# =============================================================================
# SOC Copilot — Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
# The application works fully offline with sensible defaults.
# These variables are OPTIONAL overrides.
# =============================================================================

# --- Paths ---
# Directory containing trained ML models (.joblib files)
SOC_COPILOT_MODELS_DIR=data/models

# Directory for application logs
SOC_COPILOT_LOG_DIR=logs

# Directory for ingestion config
SOC_COPILOT_CONFIG_DIR=config

# --- ML Model Settings ---
# Anomaly score thresholds (0.0 – 1.0)
# SOC_COPILOT_ANOMALY_LOW_THRESHOLD=0.3
# SOC_COPILOT_ANOMALY_HIGH_THRESHOLD=0.7

# Alert priority thresholds
# SOC_COPILOT_PRIORITY_CRITICAL=0.85
# SOC_COPILOT_PRIORITY_HIGH=0.70
# SOC_COPILOT_PRIORITY_MEDIUM=0.50
# SOC_COPILOT_PRIORITY_LOW=0.30

# --- System Log Ingestion ---
# Set to true to enable Windows Event Log ingestion (requires admin)
SOC_COPILOT_SYSTEM_LOGS_ENABLED=true

# Export interval in seconds
SOC_COPILOT_EXPORT_INTERVAL=5

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
SOC_COPILOT_LOG_LEVEL=INFO

# --- UI ---
# Application theme: dark, light
# SOC_COPILOT_THEME=dark
